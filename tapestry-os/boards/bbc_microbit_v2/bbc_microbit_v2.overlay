/*
 * Expose I2C on edge-connector pins 19 (P0.26 = SCL) and 20 (P1.00 = SDA)
 * using the GPIO bitbang driver.  The hardware TWIM1 peripheral shares an
 * address with SPIM1 and requires more DTS scaffolding; the bitbang driver
 * is simpler and sufficient for 100 kHz Cutebot register writes.
 */

/ {
    cutebot_i2c: cutebot-i2c {
        compatible = "gpio-i2c";
        sda-gpios = <&gpio1 0 (GPIO_ACTIVE_HIGH | GPIO_OPEN_DRAIN)>;
        scl-gpios = <&gpio0 26 (GPIO_ACTIVE_HIGH | GPIO_OPEN_DRAIN)>;
        #address-cells = <1>;
        #size-cells = <0>;
        clock-frequency = <I2C_BITRATE_STANDARD>;
    };
};
