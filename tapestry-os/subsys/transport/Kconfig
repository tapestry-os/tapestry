# Kconfig — Tapestry L3 Transport / Wire Protocol
#
# Source this from your application Kconfig with:
#   rsource "../tapestry-os/subsys/transport/Kconfig"

config TAPESTRY_WIRE_AUTH_ENABLED
	bool "Enable HMAC-SHA256 gossip frame authentication"
	depends on MBEDTLS
	default n
	help
	  When enabled each transmitted gossip frame is signed with a 4-byte
	  truncated HMAC-SHA256 tag (first 4 bytes of the full digest) appended
	  after the frame bytes.  Received frames whose tag does not match the
	  expected value are silently dropped and logged at WRN level.

	  All elements in a deployment must use the same key
	  (CONFIG_TAPESTRY_WIRE_AUTH_KEY) or gossip will not flow.

	  When disabled the wire format is unchanged: no tag bytes are appended
	  and no crypto dependency is introduced.

config TAPESTRY_WIRE_AUTH_KEY
	string "HMAC-SHA256 pre-shared deployment key"
	depends on TAPESTRY_WIRE_AUTH_ENABLED
	default "tapestry-insecure-default"
	help
	  ASCII string used as the HMAC-SHA256 key.  Change this from the
	  default before deploying hardware; all elements in a deployment must
	  share the same key string.

config TAPESTRY_AUTO_ID_WINDOW_MS
	int "Auto-ID nonce exchange window duration (ms)"
	default 4000
	help
	  Duration of the boot-time nonce exchange window used by the auto-ID
	  protocol.  All co-booting elements must agree on this value implicitly
	  (no explicit end-of-window signal is exchanged), so it must be the same
	  across every element in a deployment.

	  During this window each booting element advertises id=ELEMENT_ID_INVALID
	  with its hardware nonce.  After the window each element rank-orders the
	  collected nonces and assigns itself the corresponding unclaimed ID.

	  Increase if boot-time radio congestion or slow BLE stack bring-up causes
	  elements to miss peers' nonce beacons (symptom: duplicate IDs at startup).
	  Decrease on faster hardware where 4 s of idle startup is undesirable.

config TAPESTRY_MESH_RELAY
	bool "Two-hop opportunistic relay forwarding (BATMAN-inspired mesh)"
	default n
	help
	  When enabled, elements that receive a gossip frame for peer X
	  re-advertise it (with hop_count decremented) if X's logical_clock is
	  newer than the last-relayed clock tracked for X.  This allows elements
	  out of direct radio range to receive peer updates via an intermediate
	  relay node.

	  hop_count starts at 2 for first-party frames and is decremented by
	  each relay; frames with hop_count == 0 are not re-advertised, capping
	  relay depth at two hops to prevent broadcast storms.  A per-relay
	  jitter of 0-50 ms is introduced before re-advertising to reduce
	  collision probability on dense networks.

	  Relay logic (ring buffer, last-relayed clock table, flush timer) is
	  compiled out when this option is disabled, preserving identical
	  single-hop broadcast behaviour on memory-constrained targets.
